---
import { Icon } from "astro-icon/components";

interface Achievement {
	title: string;
	event?: string;
	date: string;
	description?: string;
	icon?: string;
}

interface Props {
	achievements: Achievement[];
}

const { achievements } = Astro.props;

// Sort achievements by date (newest first)
const sortedAchievements = [...achievements].sort((a, b) => {
	const dateA = new Date(a.date);
	const dateB = new Date(b.date);
	return dateB.getTime() - dateA.getTime();
});

function formatDate(dateStr: string): string {
	const date = new Date(dateStr);
	return date.toLocaleDateString("en-US", {
		day: "numeric",
		month: "short",
		year: "numeric",
	});
}
---

<div class="achievement-timeline">
	{
		sortedAchievements.map((achievement, index) => (
			<div class="achievement-item group">
				{/* Timeline line */}
				<div class="timeline-line">
					<div class="timeline-dot" />
					{index !== sortedAchievements.length - 1 && <div class="timeline-connector" />}
				</div>

				{/* Content card */}
				<div class="achievement-card">
					<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-2">
						<div class="flex items-center gap-2 flex-wrap">
							<h3 class="text-lg font-bold text-90 group-hover:text-[var(--primary)] transition">
								{achievement.title}
							</h3>
							{achievement.event && (
								<div class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-[var(--primary)]/10 text-[var(--primary)] text-xs font-semibold">
									<Icon name="material-symbols:trophy-outline" class="text-[0.75rem]" />
									{achievement.event}
								</div>
								)}
						</div>
						<span class="text-sm text-50 font-medium whitespace-nowrap flex items-center gap-1.5 flex-shrink-0">
							<Icon name="material-symbols:calendar-month-outline" class="text-[1rem]" />
							{formatDate(achievement.date)}
						</span>
					</div>

					{achievement.description && (
						<p class="text-75 text-sm leading-relaxed">{achievement.description}</p>
					)}
				</div>
			</div>
		))
	}
</div>

<style>
	.achievement-timeline {
		@apply flex flex-col gap-0;
	}

	.achievement-item {
		@apply flex gap-4 relative;
	}

	.timeline-line {
		@apply flex flex-col items-center flex-shrink-0;
		@apply w-8;
	}

	.timeline-dot {
		@apply w-3 h-3 rounded-full bg-[var(--primary)];
		@apply transition-all duration-300;
		box-shadow: 0 0 0 4px color-mix(in oklch, var(--primary) 20%, transparent);
	}

	.group:hover .timeline-dot {
		box-shadow: 0 0 0 8px color-mix(in oklch, var(--primary) 20%, transparent);
	}

	.timeline-connector {
		@apply w-0.5 flex-1 bg-[var(--line-divider)];
		@apply min-h-[2rem];
	}

	.achievement-card {
		@apply flex-1 pb-8;
	}

	.achievement-item:last-child .achievement-card {
		@apply pb-0;
	}
</style>
