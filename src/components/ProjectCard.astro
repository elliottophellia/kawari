---
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import PostMetadata from "./PostMeta.astro";

interface Props {
	entry: CollectionEntry<"projects">;
	url: string;
	class?: string;
	style?: string;
}

const { entry, url, style } = Astro.props;
const className = Astro.props.class;

const {
	title,
	description,
	published,
	updated,
	role,
	techStack = [],
	repoUrl,
	demoUrl,
} = entry.data;
---

<div class:list={["card-base flex flex-col w-full rounded-[var(--radius-large)] overflow-hidden relative border border-black/10 dark:border-white/10 hover:border-[var(--primary)]/30 transition-all", className]} style={style}>
    <div class="px-6 md:px-8 py-6 flex flex-col gap-3">
        <div class="flex flex-row justify-between items-start gap-3">
            <div class="flex-1 min-w-0">
                <a href={url}
                   class="transition group w-full block font-bold mb-1 text-2xl text-90
                        hover:text-[var(--primary)] dark:hover:text-[var(--primary)]
                        active:text-[var(--title-active)] dark:active:text-[var(--title-active)]
                ">
                    {title}
                    <Icon class="inline text-[1.5rem] text-[var(--primary)] md:hidden translate-y-0.5 absolute" name="material-symbols:chevron-right-rounded" ></Icon>
                    <Icon class="text-[var(--primary)] text-[1.5rem] transition hidden md:inline translate-y-0.5 opacity-0 group-hover:opacity-100 -translate-x-1 group-hover:translate-x-0" name="material-symbols:chevron-right-rounded"></Icon>
                </a>
                {role && <div class="text-sm text-50">Role: {role}</div>}
            </div>
        </div>

        <PostMetadata class="mb-2" published={published} updated={updated}></PostMetadata>

        <div class:list={["transition text-75 mb-2 pr-1", {"line-clamp-3": !description}]}>
            {description || "No description provided."}
        </div>

        {techStack.length > 0 && (
            <div class="flex flex-wrap gap-2">
                {techStack.map((tech) => (
                    <div class="px-3 py-1 rounded-lg bg-black/5 dark:bg-white/10 text-xs font-semibold text-50">{tech}</div>
                ))}
            </div>
        )}

        <div class="flex flex-wrap gap-2 pt-1">
            <a href={url} class="btn-regular h-10 px-4 rounded-lg font-bold active:scale-95">View details</a>
            {demoUrl && <a href={demoUrl} class="btn-plain h-10 px-4 rounded-lg font-bold active:scale-95" target="_blank" rel="noreferrer">View docs / demo</a>}
            {repoUrl && <a href={repoUrl} class="btn-plain h-10 px-4 rounded-lg font-bold active:scale-95" target="_blank" rel="noreferrer">View source</a>}
        </div>
    </div>
</div>
