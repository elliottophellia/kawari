---
import ProjectCard from "@components/ProjectCard.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedProjects } from "../utils/content-utils";
import { url } from "@utils/url-utils";

const projects = await getSortedProjects();
---

<MainGridLayout title="Projects" description="A collection of open-source projects by Reidho Satria.">
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4">
        <div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
            <div class="text-sm font-semibold text-[var(--primary)] uppercase tracking-wide">Projects</div>
            <h1 class="text-3xl md:text-4xl font-bold text-90 mb-3 leading-snug">Open-Source Projects I build and maintain</h1>
            <p class="text-75">A collection of open-source projects focused on cybersecurity and ctf challenges.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        {projects.map((entry, idx) => (
            <ProjectCard
                    entry={entry}
                    url={url(`/projects/${entry.slug}/`)}
                    class:list="onload-animation"
                    style={`animation-delay: calc(var(--content-delay) + ${idx * 60}ms);`}
            />
        ))}
    </div>
</MainGridLayout>
