---
import AchievementCard from "@components/AchievementCard.astro";
import ProjectCard from "@components/ProjectCard.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedAchievements, getSortedProjects } from "@utils/content-utils";
import { url } from "@utils/url-utils";

const achievements = await getSortedAchievements();
const projects = await getSortedProjects();
const recentAchievements = achievements.slice(0, 3);
const featured = projects.slice(0, 4);
---

<MainGridLayout title="Reidho Satria" description="A passionate CTF Player & Network Security Engineer specializing in cryptography, binary exploitation, and reverse engineering.">
    <div class="card-base px-6 md:px-9 py-7 rounded-[var(--radius-large)] onload-animation">
        <div class="flex flex-col gap-3">
            <div class="text-sm font-semibold text-[var(--primary)] uppercase tracking-wide">CTF Player &amp; Network Security Engineer</div>
            <h1 class="text-3xl md:text-4xl font-bold text-90 leading-snug">
                Hi, I&apos;m Reidho Satria.
            </h1>
            <div class="text-75 md:text-lg">
                A passionate CTF Player & Network Security Engineer specializing in cryptography, binary exploitation, and reverse engineering. With hands-on experience building actively maintained hacking tools and participating in various CTF competitions, I love tackling complex challenges and continuously learning new technologies.
            </div>
            <div class="flex flex-wrap gap-2 text-sm text-50">
                <div class="px-3 py-1 rounded-lg bg-black/5 dark:bg-white/10 transition">Palembang, Indonesia</div>
                <div class="px-3 py-1 rounded-lg bg-black/5 dark:bg-white/10 transition">CTF &amp; Network Engineering</div>
                <div class="px-3 py-1 rounded-lg bg-black/5 dark:bg-white/10 transition">GNU/Linux Enthusiast</div>
            </div>
            <div class="flex flex-wrap gap-3 pt-2">
                <a href={url("/projects/")} class="btn-regular h-11 px-4 rounded-xl font-bold active:scale-95">View Projects</a>
                <a href={url("/about/")} class="btn-plain h-11 px-4 rounded-xl font-bold active:scale-95">About Me</a>
                <a href={url("/contact/")} class="btn-plain h-11 px-4 rounded-xl font-bold active:scale-95">Get in Touch</a>
            </div>
        </div>
    </div>

    <div class="card-base px-6 md:px-8 py-6 rounded-[var(--radius-large)] mt-4 onload-animation">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-3 mb-5">
            <div>
                <div class="text-sm font-semibold text-[var(--primary)] uppercase tracking-wide">Projects</div>
                <h2 class="text-2xl font-bold text-90">Featured Projects</h2>
                <p class="text-50 mt-1">A selection of open-source projects I build and maintain.</p>
            </div>
            <a href={url("/projects/")} class="btn-plain h-10 px-4 rounded-lg font-bold active:scale-95">View all projects</a>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            {featured.map((entry, idx) => (
                <ProjectCard
                        entry={entry}
                        url={url(`/projects/${entry.slug}/`)}
                        class:list="onload-animation"
                        style={`animation-delay: calc(var(--content-delay) + ${idx * 80}ms);`}
                />
            ))}
        </div>
    </div>

    <div class="card-base px-6 md:px-8 py-6 rounded-[var(--radius-large)] mt-4 onload-animation">
        <div class="flex flex-col gap-4">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-3">
                <div>
                    <div class="text-sm font-semibold text-[var(--primary)] uppercase tracking-wide">Experience</div>
                    <h2 class="text-2xl font-bold text-90">Professional Journey</h2>
                    <p class="text-50 mt-1">Where I've applied my skills in real-world environments.</p>
                </div>
                <a href={url("/about/")} class="btn-plain h-10 px-4 rounded-lg font-bold active:scale-95">Full resume</a>
            </div>
            <div class="grid grid-cols-1 gap-4">
                <div class="p-4 rounded-xl bg-black/5 dark:bg-white/5 border border-black/5 dark:border-white/10 transition hover:bg-black/8 dark:hover:bg-white/8">
                    <div class="flex flex-col md:flex-row md:items-start justify-between gap-2">
                        <div class="flex-1">
                            <div class="flex items-center gap-2 flex-wrap">
                                <h3 class="font-bold text-90">Network Security Engineer</h3>
                                <span class="text-xs px-2 py-0.5 rounded-full bg-[var(--primary)]/10 text-[var(--primary)] font-medium">Internship</span>
                            </div>
                            <div class="text-sm text-[var(--primary)] font-medium mt-1">Universitas Indo Global Mandiri</div>
                            <ul class="text-50 text-sm mt-2 space-y-1 list-disc list-inside">
                                <li>Assisted in securing campus networks and implementing monitoring solutions.</li>
                                <li>Identified and mitigated vulnerabilities in the university's web applications.</li>
                                <li>Successfully stopped a DDoS attack targeting public-facing services.</li>
                            </ul>
                        </div>
                        <div class="text-sm text-50 font-medium whitespace-nowrap">2025 – Present</div>
                    </div>
                </div>
                <div class="p-4 rounded-xl bg-black/5 dark:bg-white/5 border border-black/5 dark:border-white/10 transition hover:bg-black/8 dark:hover:bg-white/8">
                    <div class="flex flex-col md:flex-row md:items-start justify-between gap-2">
                        <div class="flex-1">
                            <div class="flex items-center gap-2 flex-wrap">
                                <h3 class="font-bold text-90">Automation Developer</h3>
                                <span class="text-xs px-2 py-0.5 rounded-full bg-[var(--primary)]/10 text-[var(--primary)] font-medium">Freelance</span>
                            </div>
                            <div class="text-sm text-[var(--primary)] font-medium mt-1">Self-Employed</div>
                            <ul class="text-50 text-sm mt-2 space-y-1 list-disc list-inside">
                                <li>Developed custom automation bots for various client needs.</li>
                                <li>Built web automation tools for registration and data extraction tasks.</li>
                            </ul>
                        </div>
                        <div class="text-sm text-50 font-medium whitespace-nowrap">2022 – 2024</div>
                    </div>
                </div>
                <div class="p-4 rounded-xl bg-black/5 dark:bg-white/5 border border-black/5 dark:border-white/10 transition hover:bg-black/8 dark:hover:bg-white/8">
                    <div class="flex flex-col md:flex-row md:items-start justify-between gap-2">
                        <div class="flex-1">
                            <div class="flex items-center gap-2 flex-wrap">
                                <h3 class="font-bold text-90">Front-end Developer & Whitelist Staff</h3>
                                <span class="text-xs px-2 py-0.5 rounded-full bg-[var(--primary)]/10 text-[var(--primary)] font-medium">Freelance</span>
                            </div>
                            <div class="text-sm text-[var(--primary)] font-medium mt-1">PT Datenshi Games Indonesia</div>
                            <ul class="text-50 text-sm mt-2 space-y-1 list-disc list-inside">
                                <li>Filtering players to identify and flag cheaters.</li>
                                <li>Contributed to the creation of the whitelist website.</li>
                            </ul>
                        </div>
                        <div class="text-sm text-50 font-medium whitespace-nowrap">2021 – 2022</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card-base px-6 md:px-8 py-6 rounded-[var(--radius-large)] mt-4 onload-animation">
        <div class="flex flex-col gap-4">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-3">
                <div>
                    <div class="text-sm font-semibold text-[var(--primary)] uppercase tracking-wide">Education</div>
                    <h2 class="text-2xl font-bold text-90">Academic Background</h2>
                    <p class="text-50 mt-1">My educational journey in tech and computer science.</p>
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="p-4 rounded-xl bg-black/5 dark:bg-white/5 border border-black/5 dark:border-white/10 transition hover:bg-black/8 dark:hover:bg-white/8">
                    <div class="flex flex-col gap-1">
                        <div class="flex items-center gap-2 flex-wrap">
                            <h3 class="font-bold text-90">Bachelor of Computer Science</h3>
                            <span class="text-xs px-2 py-0.5 rounded-full bg-[var(--primary)]/10 text-[var(--primary)] font-medium">Ongoing</span>
                        </div>
                        <div class="text-sm text-[var(--primary)] font-medium">University of Indo Global Mandiri</div>
                        <div class="text-sm text-50 font-medium">2024 – Present</div>
                        <div class="flex flex-wrap gap-2 text-xs text-50 mt-2">
                            <div class="px-2 py-0.5 rounded-md bg-black/5 dark:bg-white/10 transition">Computer Science</div>
                        </div>
                    </div>
                </div>
                <div class="p-4 rounded-xl bg-black/5 dark:bg-white/5 border border-black/5 dark:border-white/10 transition hover:bg-black/8 dark:hover:bg-white/8">
                    <div class="flex flex-col gap-1">
                        <h3 class="font-bold text-90">High School Diploma</h3>
                        <div class="text-sm text-[var(--primary)] font-medium">State Vocational High School No.4 Palembang</div>
                        <div class="text-sm text-50 font-medium">2019 – 2022</div>
                        <div class="flex flex-wrap gap-2 text-xs text-50 mt-2">
                            <div class="px-2 py-0.5 rounded-md bg-black/5 dark:bg-white/10 transition">Computer And Network Engineering</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card-base px-6 md:px-8 py-6 rounded-[var(--radius-large)] mt-4 onload-animation">
        <div class="flex flex-col gap-4">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-3">
                <div>
                    <div class="text-sm font-semibold text-[var(--primary)] uppercase tracking-wide">Achievements</div>
                    <h2 class="text-2xl font-bold text-90">Recent Competition Highlights</h2>
                    <p class="text-50 mt-1">A few highlights from recent competitions. The rest lives in the full archive.</p>
                </div>
                <a href={url("/achievements/")} class="btn-plain h-10 px-4 rounded-lg font-bold active:scale-95">View all achievements</a>
            </div>
            <div class="grid grid-cols-1 xl:grid-cols-3 gap-4">
                {recentAchievements.map((entry, idx) => (
                    <AchievementCard
                        entry={entry}
                        class="onload-animation"
                        style={`animation-delay: calc(var(--content-delay) + ${idx * 70}ms);`}
                    />
                ))}
            </div>
        </div>
    </div>

    <div class="card-base px-6 md:px-8 py-6 rounded-[var(--radius-large)] mt-4 onload-animation">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-3">
            <div>
                <div class="text-sm font-semibold text-[var(--primary)] uppercase tracking-wide">Collaboration</div>
                <h2 class="text-2xl font-bold text-90">Let&apos;s build together</h2>
                <p class="text-75 mt-1">I&apos;m always open to collaborating on exciting projects.</p>
            </div>
            <div class="flex flex-wrap gap-3">
                <a href="/contact/" class="btn-regular h-11 px-4 rounded-xl font-bold active:scale-95">Contact</a>
                <a href="https://github.com/elliottophellia" class="btn-plain h-11 px-4 rounded-xl font-bold active:scale-95" target="_blank" rel="noreferrer">GitHub</a>
            </div>
        </div>
    </div>
</MainGridLayout>
